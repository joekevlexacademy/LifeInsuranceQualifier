# GHL Marketplace App credentials (from GHL developer portal)
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=

# Supabase project credentials (from Supabase project settings)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Public URL of this Railway deployment (no trailing slash)
APP_BASE_URL=https://your-app.railway.app

# Only needed for white-label GHL accounts with a custom domain.
# Leave blank to use the standard marketplace.gohighlevel.com OAuth URL.
GHL_OAUTH_DOMAIN=
